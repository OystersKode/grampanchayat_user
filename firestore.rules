rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper to check if user is logged in (including Guest/Anonymous)
    function isAuthenticated() {
      return request.auth != null;
    }

    // NEWS: Anyone can read, logged-in users can update (for like_count)
    match /news/{id} {
      allow read: if true;
      allow update: if isAuthenticated();

      // Images subcollection
      match /images/{imageId} {
        allow read: if true;
      }
    }

    // WISHES: Anyone can read, logged-in users can update
    match /wishes/{id} {
      allow read: if true;
      allow update: if isAuthenticated();
    }

    // LIKES: Logged-in users can manage likes
    match /likes/{id} {
      allow read: if true;
      allow create, delete: if isAuthenticated();
    }

    // GUEST USERS: Users can manage their own profile
    match /guest_users/{uid} {
      allow read, write: if isAuthenticated() && request.auth.uid == uid;
    }

    // MEMBER REQUESTS
    match /member_requests/{id} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && resource.data.user_uid == request.auth.uid;
    }
  }
}
