rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
         get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    // NEWS
    match /news/{id} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAuthenticated(); // Allow users to increment like_count

      match /images/{imageId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // ANNOUNCEMENTS
    match /announcements/{id} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAuthenticated(); // Allow users to increment like_count
    }

    // WISHES
    match /wishes/{id} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAuthenticated(); // Allow users to increment like_count
    }

    // LIKES
    match /likes/{id} {
      allow read: if true;
      allow create, delete: if isAuthenticated();
    }

    // FEEDBACK
    match /feedback/{id} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
    }

    // GUEST USERS
    match /guest_users/{uid} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == uid);
      allow write: if isAuthenticated() && request.auth.uid == uid;
    }

    // MEMBER REQUESTS
    match /member_requests/{id} {
      allow create: if isAuthenticated();
      allow read: if isAdmin() || (isAuthenticated() && resource.data.user_uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ADMINS
    match /admins/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
      allow write: if false;
    }
  }
}
